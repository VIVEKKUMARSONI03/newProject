<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders</title>
</head>
<body>

    <% if (!orders || orders.length === 0) { %>
        <h3>No orders yet</h3>
    <% } else { %>
        <ul>
            <% orders.forEach(order => { %>
                <li>
                    Order ID: <%= order._id %><br>
                    User Name: <%= order.name %><br>
                    Delivery location : <%= order.location.placename %><br>
                    Mode of payment: <%= order.payment_mode %>
                </li>
            <% }); %>
        </ul>
    <% } %>

</body>
</html>
