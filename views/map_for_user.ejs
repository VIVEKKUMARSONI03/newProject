<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/map_for_user.css">
</head>

<body>
    <div class="info-grid">
     <div class="info-item">
    <h3 id = 'name'>name: <%= name %></h3>
    </div>
     <div class="info-item">
    <h3 id = 'email'>email: <%= email %></h3>
    </div>
     <div class="info-item">
    <h3 id = 'bcode'>bcode : <%= bcode %></h3>
    </div>
     <div class="info-item">
    <h3 id = 'lat' >lat : <%= lat %></h3>
    </div>
     <div class="info-item">
    <h3 id = 'lng'>lng : <%= lng %></h3>
    </div>
     <div class="info-item">
    <h3 id = 'placename'>placename: <%= placename %></h3>
    </div>
    <div id="map" style="height: 100vh;"></div>
    </div>
    

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/user_map_script.js"></script>
</body>

</html>