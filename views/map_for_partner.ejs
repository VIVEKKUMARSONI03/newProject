<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/map_for_partner.css">
</head>

<body>
    <div class='details'>
        <h3 id='name'>name: <%= name %>
        </h3>
        <h3 id='email'>email: <%= email %>
        </h3>
        <h3 id='bcode'>bcode : <%= bcode %>
        </h3>

    </div>
    <div id="map"></div>

    <div id='cover' class='cover'>
        <div id='confirm_delivery' class='confirm_delivery'>
            <h3>your order is approx 5 meter away</h3>

            <label>
                <input type="checkbox" id="payment_box">
                Payment Done
            </label>
            <br>

            <label>
                <input type="checkbox" id="right_user">
                Right User
            </label>
            <br><br>

            <button id="confirmed" disabled>Deliver</button>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/partner_map_script.js"></script>
</body>

</html>