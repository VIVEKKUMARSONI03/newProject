<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>welcome to admin home</h1>

    <h3 id = 'name'>name : <%= name %>
    </h3>
    <h3 id = 'email'>email :<%= email %>
    </h3>
    <h3 id = 'aloc'>loc : <%= loc %></h3>

    <form action='/admin/add_branch' method='POST'>
        <input type='text' name='name' placeholder='branch name'>
        <input type='number' name='location' placeholder='location'>
        <input type='number' name='contactInfo' placeholder='contact number'>
        <button type='submit'>submin</button>
    </form>

    <form action='/admin/<%= email %>/get_orders' method='POST'>
        <button type='submit'>get orders list</button>
    </form>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/admin_script.js"></script>
</body>

</html>