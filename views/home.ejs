<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="/user_home.css">
</head>

<body>
    <h2>welcome to user home</h2>
    <div class="user-info">
        <h3 id='name'>name: <%= name %>
        </h3>
        <h3 id='email'>email: <%= email %>
        </h3>
        <h3 id='bcode'>bcode : <%= bcode %>
        </h3>
    </div>

    <div class="order-status">
        <% let orderlist=has_order; %>

            <% if (orderlist.length> 0) { %>
                <h3>Your order is: <%= orderlist[0] %>
                </h3>
                <% } else { %>
                    <h3>You don't have any orders yet</h3>
                    <% } %>
    </div>

    <div class="form-container">
    <form action='/user/order/<%= email %>' method='POST'>
        <label for="payment_mode"> make an order</label>

        <select name='payment_mode' id='payment_mode' required>
            <option value="">mode of payment</option>
            <option value="oneline">online</option>
            <option value="cod">cod</option>
        </select>
        
        <button type='submit'>place</button>
    </form>

    <form action='/user/manage_orders/<%= email %>' method='POST'>
        <input type='hidden' name='orderId' value='<%= orderlist[0] %>'>
        <button type='submit'>manage orders</button>
    </form>
    </div>

    <div id='cover' class='cover'>
        <div id='confirm_delivery' class='confirm_delivery'>
            <h3>your order is approx 5 meter away</h3>

            <form action="/user/delivered/<%= email %>" method="POST">
                <button type="submit" id="me" value="me">
                    Yes, it is me
                </button>
            </form>

            <button id='not_me' value="not_me">no it is not me</button>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/user_home_script.js"></script>
</body>

</html>